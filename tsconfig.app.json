{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ES2020",
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "skipLibCheck": true,
    /* Bundler Mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": false,
    "isolatedModules": true,
    "moduleDetection": "force",
    "resolveJsonModule": true,
    "noEmit": true,
    "jsx": "react-jsx",
    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    //    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    /* Intract Specific Settings */
    "allowJs": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "noImplicitAny": true,
    "forceConsistentCasingInFileNames": false,
    "emitDeclarationOnly": false,
    "baseUrl": "./",
    "rootDir": "./src/",
    "paths": {
      "@/*": [
        "src/*",
        "src/components/*"
      ],
      "@intractinc/base/*": [
        "intract/base/lib/*"
      ]
    }
  },
  "include": [
    "intract/base/lib/types/**/*.d.ts",
    "src/**/*"
  ],
  "exclude": [
    "**/node_modules",
    "build"
  ],
  "references": [
    {
      "path": "./intract/base/tsconfig.json"
    },
    {
      "path": "./intract/engine/tsconfig.json"
    }
  ]
}
